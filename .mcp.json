{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "firefox"
      ],
      "env": {}
    },
    "memex": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "memex",
        "mcp",
        "run"
      ],
      "env": {
        "MEMEX_SERVER_URL": "http://host.docker.internal:8000",
        "MEMEX_VAULT__ACTIVE": "memex",
        "MEMEX_VAULT__SEARCH": "[\"memex\"]"
      }
    }
  }
}
