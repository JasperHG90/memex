{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "firefox"
      ],
      "env": {}
    },
    "memex": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "memex-cli[mcp] @ git+https://github.com/JasperHG90/memex.git@main#subdirectory=packages/cli",
        "memex",
        "mcp",
        "run"
      ],
      "env": {
        "MEMEX_SERVER_URL": "http://host.docker.internal:8000"
      }
    }
  }
}
